# pyenv
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if platform is not identical, locking can fail.
#   Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally recommended, but optional.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally recommended, but optional.
#   pdm.lock

# PEP 582; project packages folder (e.g. pdm)
__pypackages__/

