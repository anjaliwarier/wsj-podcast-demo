# Google Cloud Project & Execution Settings
GOOGLE_CLOUD_PROJECT=warier-agents
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_STORAGE_BUCKET=warier-agents
MODEL_NAME=gemini-2.5-pro

# Synthetic Data & Bypass Settings
USE_SYNTHETIC_LOCAL_MOCK=True

# Email Integration (When not in Mock Mode)
GMAIL_SMTP_SERVER=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_SENDER_EMAIL=cloud.architect@warieragents.internal
GMAIL_APP_PASSWORD=your-app-password
GMAIL_RECIPIENT_EMAIL=architect.lead@warieragents.internal
